# =============================================================================
# zhipuAIWeb 环境配置示例（复制为 .env 后填写）
# =============================================================================

# Gemini API（module3 诊断服务）
Gemini_API_KEY=your_api_key_here
Gemini_BASE_URL=https://api-gateway.glm.ai
Gemini_MODEL_NAME=gemini-3-pro-preview

# Flask 服务
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
FLASK_DEBUG=true
